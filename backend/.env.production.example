NODE_ENV=production
TRUST_PROXY=1
CORS_ORIGINS=https://your-admin-domain.example,https://your-student-domain.example

# Supabase pooled PostgreSQL connection.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-region.pooler.supabase.com:5432/postgres
DB_SSL=true

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=8h

# Vercel does not have persistent disk. Use Supabase Storage or another S3-compatible store.
STORAGE_DRIVER=s3
S3_REGION=ap-south-1
S3_BUCKET=question-papers
S3_ACCESS_KEY_ID=<supabase-storage-access-key>
S3_SECRET_ACCESS_KEY=<supabase-storage-secret-key>
S3_ENDPOINT=https://<project-ref>.supabase.co/storage/v1/s3
S3_PUBLIC_BASE_URL=

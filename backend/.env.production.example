NODE_ENV=production
TRUST_PROXY=1
CORS_ORIGINS=https://your-admin-domain.example,https://your-student-domain.example

# PostgreSQL connection on the application server.
DATABASE_URL=
DB_SSL=false

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=8h
JWT_ISSUER=epolypariksha-hp-api
JWT_AUDIENCE=epolypariksha-hp-mobile
CORS_ORIGINS=https://admin.example.edu

# Store uploads locally, or configure an S3-compatible provider when needed.
STORAGE_DRIVER=local
S3_REGION=ap-south-1
S3_BUCKET=question-papers
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_PUBLIC_BASE_URL=

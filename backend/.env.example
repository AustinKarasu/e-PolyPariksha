PORT=4000
NODE_ENV=development
TRUST_PROXY=0
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# PostgreSQL. Use either DATABASE_URL or the individual DB_* fields.
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=postgres
DB_SSL=false

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=8h
JWT_ISSUER=epolypariksha-hp-api
JWT_AUDIENCE=epolypariksha-hp-mobile
# Comma-separated browser origins. Leave empty only for native mobile clients.
CORS_ORIGINS=https://admin.example.edu
BODY_LIMIT=1mb
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=8
GLOBAL_RATE_LIMIT_WINDOW_MS=60000
GLOBAL_RATE_LIMIT_MAX=120
STORAGE_DRIVER=local
UPLOAD_DIR=uploads

# Optional S3-compatible object storage.
S3_REGION=ap-south-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_PUBLIC_BASE_URL=

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
